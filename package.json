{
  "name": "github-status-card",
  "version": "1.1.2",
  "description": "A live GitHub activity status card for portfolios",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --watch --format esm,cjs --dts",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/etor01/github-status-card.git"
  },
  "keywords": [
    "github",
    "status",
    "activity",
    "react-component",
    "developer-status",
    "portfolio-widget",
    "github-activity"
  ],
  "author": "Etornam Kordzo Ahiataku",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/etor01/github-status-card/issues"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "homepage": "https://github.com/etor01/github-status-card#readme",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
